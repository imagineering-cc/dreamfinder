# Anthropic
ANTHROPIC_API_KEY=

# Signal (signal-cli-rest-api)
SIGNAL_API_URL=http://localhost:8080
SIGNAL_PHONE_NUMBER=+1234567890

# Kan.bn
KAN_BASE_URL=https://tasks.example.com/api/v1
KAN_API_KEY=

# Outline
OUTLINE_BASE_URL=https://kb.example.com/api
OUTLINE_API_KEY=

# Radicale (optional)
RADICALE_BASE_URL=https://dav.example.com
RADICALE_USERNAME=dreamfinder
RADICALE_PASSWORD=

# Calendar awareness (optional — requires Radicale)
CALENDAR_URL=https://dav.example.com/dreamfinder/imagineering-events/
EVENT_TIMEZONE=Australia/Melbourne

# Playwright (optional — enables web browsing tools)
PLAYWRIGHT_ENABLED=false

# Escalation alerts (optional) — used by the self-healing brain to alert a
# human via the `notify` Telegram sidecar when River's Claude access is down
# (billing/auth failure that couldn't be recovered by fallback).
# NOTE: the bot container is on the `imagineering` docker network while
# `notify` is on `notify_default`. To reach it, either add `notify_default` as
# an external network in the bot's compose, OR use host-gateway:
#   extra_hosts: ["host.docker.internal:host-gateway"]
#   NOTIFY_URL=http://host.docker.internal:8090
NOTIFY_URL=
NOTIFY_API_KEY=

# Bot Config
BOT_NAME=Dreamfinder
DATABASE_PATH=./data/bot.db
LOG_LEVEL=info
HEALTH_PORT=8081
