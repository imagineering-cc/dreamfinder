# Playwright (optional — enables web browsing tools)
PLAYWRIGHT_ENABLED=false

# MCP Server Paths (optional — override default relative paths)
KAN_MCP_PATH=

# Bot Config
BOT_NAME=Dreamfinder
DATABASE_PATH=./data/bot.db
LOG_LEVEL=info
HEALTH_PORT=8081
