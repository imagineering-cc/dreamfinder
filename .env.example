# Anthropic
ANTHROPIC_API_KEY=

# Signal (signal-cli-rest-api)
SIGNAL_API_URL=http://localhost:8080
SIGNAL_PHONE_NUMBER=+1234567890

# Kan.bn
KAN_BASE_URL=https://tasks.example.com/api/v1
KAN_API_KEY=

# Outline
OUTLINE_BASE_URL=https://kb.example.com/api
OUTLINE_API_KEY=

# Radicale (optional)
RADICALE_BASE_URL=https://dav.example.com
RADICALE_USERNAME=dreamfinder
RADICALE_PASSWORD=

# Calendar awareness (optional — requires Radicale)
CALENDAR_URL=https://dav.example.com/dreamfinder/imagineering-events/
